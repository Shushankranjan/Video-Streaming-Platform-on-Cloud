PORT=3001
DATABASE_URL=postgresql://vsp:vsp@localhost:5434/vsp
REDIS_URL=redis://localhost:6380
JWT_SECRET=local-dev-secret-change-me

# ── Feature flags (local dev — all AWS services disabled) ────────────────────
USE_LOCAL_STORAGE=true
USE_SQS=false
USE_COGNITO=false

# ── MinIO (local S3 replacement) ─────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9010
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_INGRESS_BUCKET=vsp-ingress
S3_OUTPUT_BUCKET=vsp-output

# ── Public URLs ───────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3001
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

