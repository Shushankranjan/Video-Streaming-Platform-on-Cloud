# Production environment variables for AWS deployment.
# Copy to .env and fill in values from CDK stack outputs.

PORT=3001
NODE_ENV=production

# ── Feature flags ─────────────────────────────────────────────────────────────
USE_LOCAL_STORAGE=false
USE_SQS=true
USE_COGNITO=true

# ── Database (from Secrets Manager, injected by ECS) ─────────────────────────
# DATABASE_URL is injected automatically by the ECS task definition.
# Set it here only for manual testing outside of ECS.
# DATABASE_URL=postgresql://vspdbadmin:<password>@<rds-endpoint>:5432/vsp

# ── Redis (ElastiCache) ───────────────────────────────────────────────────────
REDIS_URL=redis://<elasticache-endpoint>:6379

# ── S3 ────────────────────────────────────────────────────────────────────────
# No S3_ENDPOINT, S3_ACCESS_KEY, or S3_SECRET_KEY — ECS task role handles auth
S3_REGION=us-east-1
S3_INGRESS_BUCKET=vsp-ingress-<account-id>
S3_OUTPUT_BUCKET=vsp-output-<account-id>

# ── SQS ───────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/vsp-transcode.fifo
SQS_REGION=us-east-1

# ── Cognito ───────────────────────────────────────────────────────────────────
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=<client-id-from-cdk-output>

# ── CloudFront ────────────────────────────────────────────────────────────────
CLOUDFRONT_DOMAIN=https://XXXXXXXXXXXX.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=KXXXXXXXXXXXX
# Paste the PEM private key with \n instead of real newlines:
# CLOUDFRONT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# ── API URL (used by the worker webhook) ─────────────────────────────────────
API_BASE_URL=https://XXXXXXXXXXXX.cloudfront.net
